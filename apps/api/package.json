{
  "name": "@bio/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/index.ts",
